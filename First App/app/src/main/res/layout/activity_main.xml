<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0520"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- ═══════════════════════════════════════ -->
        <!--              HEADER BAR                  -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#0D0520"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Instructions button -->
            <Button
                android:id="@+id/btnInstructions"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:text="?"
                android:textSize="18sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:background="@drawable/bg_dissolve_button"
                android:padding="0dp" />

            <!-- App Title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚗ CAULDRON"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="serif"
                android:letterSpacing="0.15" />

            <!-- Spacer to balance layout -->
            <View
                android:layout_width="56dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════ -->
        <!--         LAST BREW BADGE (SharedPrefs)   -->
        <!-- ═══════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvLastBrew"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Last Brew: None"
            android:textColor="#B89FD4"
            android:textSize="11sp"
            android:gravity="center"
            android:fontFamily="serif"
            android:background="@drawable/bg_ingredient_display"
            app:layout_constraintTop_toBottomOf="@id/headerBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════ -->
        <!--         INGREDIENT DISPLAY BOX          -->
        <!-- ═══════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvIngredients"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:minHeight="52dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="Tap ingredients to begin brewing..."
            android:textColor="#C8A0E8"
            android:textSize="12sp"
            android:gravity="center"
            android:fontFamily="serif"
            android:background="@drawable/bg_ingredient_display"
            app:layout_constraintTop_toBottomOf="@id/tvLastBrew"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════ -->
        <!--              CAULDRON VIEW              -->
        <!-- ═══════════════════════════════════════ -->
        <FrameLayout
            android:id="@+id/cauldronContainer"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvIngredients"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Glow ring behind cauldron -->
            <View
                android:id="@+id/cauldronGlow"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:background="@drawable/bg_cauldron_glow"
                android:alpha="0.5" />

            <!-- Cauldron image (tinted dynamically) -->
            <ImageView
                android:id="@+id/ivCauldron"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cauldron"
                android:contentDescription="Brewing Cauldron"
                android:scaleType="fitCenter" />

        </FrameLayout>

        <!-- ═══════════════════════════════════════ -->
        <!--           RESULT CARD                   -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_result_card"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cauldronContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvPotionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✨ Liquid Luck"
                android:textColor="#FFD700"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/tvPotionEffect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Effect description here."
                android:textColor="#E0D0FF"
                android:textSize="12sp"
                android:gravity="center"
                android:fontFamily="serif" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════ -->
        <!--        INGREDIENT GRID (3x4)            -->
        <!-- ═══════════════════════════════════════ -->
        <GridLayout
            android:id="@+id/ingredientGrid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:columnCount="4"
            android:rowCount="3"
            android:useDefaultMargins="false"
            app:layout_constraintTop_toBottomOf="@id/resultCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Row 1: Mandrake Root -->
            <LinearLayout
                android:id="@+id/btnMandrake"
                style="@style/IngredientBtn"
                android:layout_column="0"
                android:layout_row="0">
                <TextView android:text="🌿" style="@style/IngredientEmoji"/>
                <TextView android:text="Mandrake\nRoot" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 1: Phoenix Feather -->
            <LinearLayout
                android:id="@+id/btnPhoenix"
                style="@style/IngredientBtn"
                android:layout_column="1"
                android:layout_row="0">
                <TextView android:text="🔥" style="@style/IngredientEmoji"/>
                <TextView android:text="Phoenix\nFeather" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 1: Unicorn Hair -->
            <LinearLayout
                android:id="@+id/btnUnicorn"
                style="@style/IngredientBtn"
                android:layout_column="2"
                android:layout_row="0">
                <TextView android:text="🦄" style="@style/IngredientEmoji"/>
                <TextView android:text="Unicorn\nHair" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 1: Wolfsbane -->
            <LinearLayout
                android:id="@+id/btnWolfsbane"
                style="@style/IngredientBtn"
                android:layout_column="3"
                android:layout_row="0">
                <TextView android:text="🐺" style="@style/IngredientEmoji"/>
                <TextView android:text="Wolfsbane" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 2: Bezoar -->
            <LinearLayout
                android:id="@+id/btnBezoar"
                style="@style/IngredientBtn"
                android:layout_column="0"
                android:layout_row="1">
                <TextView android:text="💎" style="@style/IngredientEmoji"/>
                <TextView android:text="Bezoar" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 2: Salamander Blood -->
            <LinearLayout
                android:id="@+id/btnSalamander"
                style="@style/IngredientBtn"
                android:layout_column="1"
                android:layout_row="1">
                <TextView android:text="🦎" style="@style/IngredientEmoji"/>
                <TextView android:text="Salamander\nBlood" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 2: Boomslang Skin -->
            <LinearLayout
                android:id="@+id/btnBoomslang"
                style="@style/IngredientBtn"
                android:layout_column="2"
                android:layout_row="1">
                <TextView android:text="🐍" style="@style/IngredientEmoji"/>
                <TextView android:text="Boomslang\nSkin" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 2: Dittany -->
            <LinearLayout
                android:id="@+id/btnDittany"
                style="@style/IngredientBtn"
                android:layout_column="3"
                android:layout_row="1">
                <TextView android:text="🌸" style="@style/IngredientEmoji"/>
                <TextView android:text="Dittany" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 3: Moonstone Powder -->
            <LinearLayout
                android:id="@+id/btnMoonstone"
                style="@style/IngredientBtn"
                android:layout_column="0"
                android:layout_row="2">
                <TextView android:text="🌙" style="@style/IngredientEmoji"/>
                <TextView android:text="Moonstone\nPowder" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 3: Dragon Scale -->
            <LinearLayout
                android:id="@+id/btnDragon"
                style="@style/IngredientBtn"
                android:layout_column="1"
                android:layout_row="2">
                <TextView android:text="🐉" style="@style/IngredientEmoji"/>
                <TextView android:text="Dragon\nScale" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 3: Nightshade -->
            <LinearLayout
                android:id="@+id/btnNightshade"
                style="@style/IngredientBtn"
                android:layout_column="2"
                android:layout_row="2">
                <TextView android:text="🍇" style="@style/IngredientEmoji"/>
                <TextView android:text="Nightshade" style="@style/IngredientLabel"/>
            </LinearLayout>

            <!-- Row 3: Mermaid Tear -->
            <LinearLayout
                android:id="@+id/btnMermaid"
                style="@style/IngredientBtn"
                android:layout_column="3"
                android:layout_row="2">
                <TextView android:text="💧" style="@style/IngredientEmoji"/>
                <TextView android:text="Mermaid\nTear" style="@style/IngredientLabel"/>
            </LinearLayout>

        </GridLayout>

        <!-- ═══════════════════════════════════════ -->
        <!--       BREW + DISSOLVE BUTTONS           -->
        <!-- ═══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/actionButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/ingredientGrid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/btnBrew"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="BREW ⚗"
                android:textColor="#1A0A2E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:background="@drawable/bg_brew_button"
                android:clickable="true"
                android:focusable="true" />

            <Button
                android:id="@+id/btnDissolve"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="DISSOLVE ↺"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_dissolve_button"
                android:elevation="4dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>