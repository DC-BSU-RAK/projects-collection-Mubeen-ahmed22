<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <!-- Glowing rune ring behind logo -->
    <View
        android:id="@+id/glowRing"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_splash_glow_ring"
        android:alpha="0.6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSplashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42"/>

    <!-- App logo (cauldron icon) -->
    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/ic_app_logo"
        android:contentDescription="Cauldron Logo"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="@id/glowRing"
        app:layout_constraintBottom_toBottomOf="@id/glowRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App name -->
    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="C A U L D R O N"
        android:textColor="#FFD700"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:letterSpacing="0.25"
        android:shadowColor="#FFD700"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="18"
        app:layout_constraintTop_toBottomOf="@id/glowRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="✦  The Alchemist\'s Calculator  ✦"
        android:textColor="#C8A0E8"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom credit -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="⚗ Brew wisely. Brew boldly."
        android:textColor="#7B5EA7"
        android:textSize="12sp"
        android:fontFamily="serif"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>