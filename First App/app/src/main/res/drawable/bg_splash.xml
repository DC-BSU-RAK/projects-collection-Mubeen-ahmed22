<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep dark base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#07021A" />
        </shape>
    </item>

    <!-- Radial purple glow from center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="60%p"
                android:centerX="0.5"
                android:centerY="0.42"
                android:startColor="#3A1060"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Subtle top vignette -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#AA07021A"
                android:endColor="#0007021A" />
        </shape>
    </item>

</layer-list>