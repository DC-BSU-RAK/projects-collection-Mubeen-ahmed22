<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#FFD700" />
            <stroke android:width="2dp" android:color="#FFF8DC" />
            <size android:width="72dp" android:height="72dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#2D1B4E" />
            <stroke android:width="2dp" android:color="#7B5EA7" />
            <size android:width="72dp" android:height="72dp" />
            <gradient
                android:angle="135"
                android:startColor="#3D2B5E"
                android:endColor="#1A0A2E"
                android:type="radial"
                android:gradientRadius="50%" />
        </shape>
    </item>
</selector>