<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="GARAGE SETTINGS"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <ImageButton
                android:id="@+id/btn_close_settings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_wear_alert"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close"
                android:padding="6dp"/>
        </LinearLayout>

        <!-- Vehicle Selection -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SELECT VEHICLE" android:textColor="@color/text_secondary"
            android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinner_vehicle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:popupBackground="#1A1A1A"
            android:theme="@style/ThemeOverlay.AppCompat.Dark"
            android:layout_marginBottom="16dp"/>

        <!-- Odometer Input -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CURRENT ODOMETER" android:textColor="@color/text_secondary"
            android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_current_odometer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:inputType="number"
            android:hint="Current mileage"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Service Target Input -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SERVICE TARGET" android:textColor="@color/text_secondary"
            android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_service_target"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:inputType="number"
            android:hint="Target mileage (e.g. 5000)"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/gold"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Toggles -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CURRENCIES" android:textColor="@color/text_secondary"
                    android:textSize="10sp"/>
                <TextView android:id="@+id/tv_currency_label" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="AED / USD"
                    android:textColor="@color/text_primary" android:textSize="14sp"/>
            </LinearLayout>
            <Switch android:id="@+id/switch_currency" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="UNITS" android:textColor="@color/text_secondary"
                    android:textSize="10sp"/>
                <TextView android:id="@+id/tv_units_label" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="KM / Miles"
                    android:textColor="@color/text_primary" android:textSize="14sp"/>
            </LinearLayout>
            <Switch android:id="@+id/switch_units" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save_settings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="SAVE CHANGES"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:background="@drawable/bg_login_btn"/>
    </LinearLayout>
</ScrollView>