<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical">

    <!-- Icon -->
    <ImageView
        android:id="@+id/iv_log_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_wear_ok"
        android:src="@drawable/ic_fuel"
        android:padding="8dp"
        android:layout_marginEnd="12dp"
        android:contentDescription="Expense type"/>

    <!-- Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_log_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oct 15"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/tv_log_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fuel – 150 AED"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_log_vehicle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(Daily Sedan)"
            android:textColor="@color/text_muted"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>