<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/ic_splash_logo"
            android:contentDescription="Shift-Spend Logo"/>

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="SHIFT-SPEND"
            android:textColor="@color/gold"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="YOUR GARAGE. YOUR WALLET."
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.2"/>

        <!-- Gold divider -->
        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@color/gold"/>

        <!-- Card container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp">

            <!-- Email field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:inputType="textEmailAddress"
                android:hint="driver@garage.com"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="16dp"
                android:imeOptions="actionNext"/>

            <!-- Password field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:inputType="textPassword"
                android:hint="••••••••"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="16dp"
                android:imeOptions="actionDone"/>

            <!-- Error text -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/crimson"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- Login button -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="ENTER THE GARAGE"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/bg_login_btn"/>

            <!-- Register button -->
            <Button
                android:id="@+id/btn_register"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="NEW DRIVER? REGISTER"
                android:textColor="@color/gold"
                android:letterSpacing="0.05"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="SHIFT-SPEND v1.0  •  © 2026"
            android:textColor="@color/text_muted"
            android:textSize="10sp"/>

    </LinearLayout>
</ScrollView>